# DRV8311H 3PWM open-loop driver verification build.
# Alias without .conf extension for west/PowerShell argument splitting.

CONFIG_APP_DRV_TEST=y

CONFIG_GPIO=y
CONFIG_PWM=y
CONFIG_FPU=y
CONFIG_FP_HARDABI=y
CONFIG_CBPRINTF_FP_SUPPORT=y

CONFIG_SERIAL=n
CONFIG_CONSOLE=y
CONFIG_RTT_CONSOLE=y
CONFIG_USE_SEGGER_RTT=y
CONFIG_PRINTK=y
CONFIG_LOG=y
CONFIG_LOG_DEFAULT_LEVEL=3
CONFIG_LOG_MODE_IMMEDIATE=y
CONFIG_SEGGER_RTT_BUFFER_SIZE_UP=4096

CONFIG_INPUT=n
CONFIG_BT=n
CONFIG_DISPLAY=n
CONFIG_SSD1306=n
CONFIG_SPI=n
CONFIG_SENSOR=n
CONFIG_CMSIS_DSP=n
