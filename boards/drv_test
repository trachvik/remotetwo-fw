/*
 * Alias without .overlay extension for west/PowerShell argument splitting.
 * Keep in sync with boards/drv_test.overlay.
 */

&pinctrl {
	pwm0_default: pwm0_default {
		group1 {
			psels = <NRF_PSEL(PWM_OUT0, 0,  7)>,  /* INA – P0.07 */
				<NRF_PSEL(PWM_OUT1, 1,  5)>,  /* INB – P1.05 */
				<NRF_PSEL(PWM_OUT2, 0, 22)>;  /* INC – P0.22 */
		};
	};
	pwm0_sleep: pwm0_sleep {
		group1 {
			psels = <NRF_PSEL(PWM_OUT0, 0,  7)>,
				<NRF_PSEL(PWM_OUT1, 1,  5)>,
				<NRF_PSEL(PWM_OUT2, 0, 22)>;
			low-power-enable;
		};
	};
};

&pwm0 {
	status = "okay";
	pinctrl-0 = <&pwm0_default>;
	pinctrl-1 = <&pwm0_sleep>;
	pinctrl-names = "default", "sleep";
};

/ {
	bldc_drv: bldc_drv {
		compatible = "remote-two,bldc-drv8311";

		pwms = <&pwm0 0 PWM_KHZ(25) PWM_POLARITY_NORMAL>,
		       <&pwm0 1 PWM_KHZ(25) PWM_POLARITY_NORMAL>,
		       <&pwm0 2 PWM_KHZ(25) PWM_POLARITY_NORMAL>;

		inl-gpios   = <&gpio0 18 GPIO_ACTIVE_HIGH>;
		sleep-gpios = <&gpio1  1 GPIO_ACTIVE_HIGH>;
		fault-gpios = <&gpio0 11 GPIO_ACTIVE_LOW>;
	};
};
