/*
 * Device Tree overlay for nRF5340 DK - remote_two
 *
 * AS5048A encoder (SPI3):
 *   SCK  -> P1.05
 *   MOSI -> P1.06
 *   MISO -> P1.02
 *   CS   -> P1.03
 *
 * SSD1309 OLED (shared SPI3 bus):
 *   CS   -> P1.09
 *   DC   -> P1.08
 *   RST  -> P1.07
 *
 * 6PWM motor driver:
 *   Phase A high -> P1.14
 *   Phase B high -> P1.12
 *   Phase C high -> P1.10
 *   Phase A low  -> P1.15
 *   Phase B low  -> P1.13
 *   Phase C low  -> P1.11
 */

&pinctrl {
	/* SPI3 - AS5048A encoder + SSD1309 display */
	spi3_default: spi3_default {
		group1 {
			psels = <NRF_PSEL(SPIM_SCK,  1, 5)>,
				<NRF_PSEL(SPIM_MOSI, 1, 6)>,
				<NRF_PSEL(SPIM_MISO, 1, 2)>;
		};
	};
	spi3_sleep: spi3_sleep {
		group1 {
			psels = <NRF_PSEL(SPIM_SCK,  1, 5)>,
				<NRF_PSEL(SPIM_MOSI, 1, 6)>,
				<NRF_PSEL(SPIM_MISO, 1, 2)>;
			low-power-enable;
		};
	};

	/* PWM0 - high-side gate signals (AH=OUT0, BH=OUT1, CH=OUT2) */
	pwm0_default: pwm0_default {
		group1 {
			psels = <NRF_PSEL(PWM_OUT0, 1, 14)>,
				<NRF_PSEL(PWM_OUT1, 1, 12)>,
				<NRF_PSEL(PWM_OUT2, 1, 10)>;
		};
	};
	pwm0_sleep: pwm0_sleep {
		group1 {
			psels = <NRF_PSEL(PWM_OUT0, 1, 14)>,
				<NRF_PSEL(PWM_OUT1, 1, 12)>,
				<NRF_PSEL(PWM_OUT2, 1, 10)>;
			low-power-enable;
		};
	};

	/* PWM1 - low-side gate signals (AL=OUT0, BL=OUT1, CL=OUT2) */
	pwm1_default: pwm1_default {
		group1 {
			psels = <NRF_PSEL(PWM_OUT0, 1, 15)>,
				<NRF_PSEL(PWM_OUT1, 1, 13)>,
				<NRF_PSEL(PWM_OUT2, 1, 11)>;
		};
	};
	pwm1_sleep: pwm1_sleep {
		group1 {
			psels = <NRF_PSEL(PWM_OUT0, 1, 15)>,
				<NRF_PSEL(PWM_OUT1, 1, 13)>,
				<NRF_PSEL(PWM_OUT2, 1, 11)>;
			low-power-enable;
		};
	};
};

/* SPI3 - AS5048A encoder (reg=0) + SSD1309 display (reg=1) */
&spi3 {
	compatible = "nordic,nrf-spim";
	status = "okay";
	pinctrl-0 = <&spi3_default>;
	pinctrl-1 = <&spi3_sleep>;
	pinctrl-names = "default", "sleep";
	cs-gpios = <&gpio1 3 GPIO_ACTIVE_LOW>,
		   <&gpio1 9 GPIO_ACTIVE_LOW>;

	as5048a: as5048a@0 {
		compatible = "ams,as5048a";
		reg = <0>;
		spi-max-frequency = <8000000>;
	};

	ssd1309: ssd1309@1 {
		compatible = "solomon,ssd1306fb";
		reg = <1>;
		spi-max-frequency = <8000000>;
		width = <128>;
		height = <64>;
		segment-offset = <0>;
		page-offset = <0>;
		display-offset = <0>;
		multiplex-ratio = <63>;
		segment-remap;
		com-invdir;
		prechargep = <0xF1>;
		reset-gpios = <&gpio1 7 GPIO_ACTIVE_LOW>;
		data-cmd-gpios = <&gpio1 8 GPIO_ACTIVE_HIGH>;
	};
};

/* PWM0 - high-side phase signals */
pwm_high: &pwm0 {
	status = "okay";
	pinctrl-0 = <&pwm0_default>;
	pinctrl-1 = <&pwm0_sleep>;
	pinctrl-names = "default", "sleep";
};

/* PWM1 - low-side phase signals */
pwm_low: &pwm1 {
	status = "okay";
	pinctrl-0 = <&pwm1_default>;
	pinctrl-1 = <&pwm1_sleep>;
	pinctrl-names = "default", "sleep";
};

/ {
	chosen {
		zephyr,display = &ssd1309;
	};

	/*
	 * 6PWM BLDC driver — channel order: AH, AL, BH, BL, CH, CL.
	 * To remap phases to different pins change only the pinctrl entries above;
	 * to swap which channel drives which phase edit the pwms list here.
	 * No C code needs to be touched.
	 */
	bldc_6pwm: bldc_6pwm {
		compatible = "remote-two,bldc-6pwm";
		pwms = <&pwm0 0 PWM_KHZ(25) PWM_POLARITY_NORMAL>,   /* Phase A high */
		       <&pwm1 0 PWM_KHZ(25) PWM_POLARITY_NORMAL>,   /* Phase A low  */
		       <&pwm0 1 PWM_KHZ(25) PWM_POLARITY_NORMAL>,   /* Phase B high */
		       <&pwm1 1 PWM_KHZ(25) PWM_POLARITY_NORMAL>,   /* Phase B low  */
		       <&pwm0 2 PWM_KHZ(25) PWM_POLARITY_NORMAL>,   /* Phase C high */
		       <&pwm1 2 PWM_KHZ(25) PWM_POLARITY_NORMAL>;   /* Phase C low  */
	};

	aliases {
		sw1 = &button1;
	};

	buttons {
		compatible = "gpio-keys";
		button1: button_1 {
			gpios = <&gpio0 24 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			label = "Menu button";
			zephyr,code = <INPUT_KEY_ENTER>;
		};
	};
};

